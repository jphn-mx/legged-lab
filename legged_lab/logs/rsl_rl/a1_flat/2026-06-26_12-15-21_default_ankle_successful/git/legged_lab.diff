+++ b/legged_lab/source/legged_lab/legged_lab/tasks/locomotion/deepmimic/mdp/events.py
@@ -36,3 +36,56 @@ def reset_from_ref(
     dof_pos = animation_term.get_dof_pos(env_ids)[:, 0, :]
     dof_vel = animation_term.get_dof_vel(env_ids)[:, 0, :]
